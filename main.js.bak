// --- Handler: open movie modal and wire modal controls ---
// Centralized handler for clicking a movie card
document.addEventListener('movieCardClick', async (e) => {
  const mediaId = e.detail.movieId;
  console.log('Modal opening for mediaId:', mediaId);
  
  try {
    let media, credits;
    
    // Determine type and fetch from appropriate API
    if (String(mediaId).startsWith('tvdb_')) {
      console.log('Fetching series details for:', mediaId);
      const seriesIdWithPrefix = String(mediaId).replace('tvdb_', '');
      console.log('Series ID after removing prefix:', seriesIdWithPrefix);
      
      // Extract numeric ID if it has a prefix like "series-411597"
      let seriesId = seriesIdWithPrefix;
      if (seriesIdWithPrefix.includes('-')) {
        const match = seriesIdWithPrefix.match(/(\d+)$/);
        if (match) {
          seriesId = match[1];
          console.log('Extracted numeric series ID:', seriesId);
        }
      }
      
      try {
        media = await getSeriesDetails(seriesId);
        console.log('Series details received:', media);
        
        if (!media) {
          console.error('getSeriesDetails returned null for ID:', seriesId, '(original mediaId:', mediaId, ')');
          showNotification('Could not load series details. The series may not be available.', true);
          return;
        }
        
        if (media && !tvdbHasEnglishOverview(media)) {
          const translation = await getSeriesTranslation(seriesId, 'eng');
          if (translation?.overview) {
            media.overviewTranslations = Array.isArray(media.overviewTranslations)
              ? [...media.overviewTranslations, { language: 'eng', overview: translation.overview }]
              : media.overviewTranslations || { eng: translation.overview };
          }
        }

        media = normalizeMediaItem(media, 'series');
        console.log('Normalized series:', media);
        
        // Enrich with English title if needed
        if (media._needsTitleTranslation) {
          console.log('Enriching series with English title during modal open...');
          media = await enrichSeriesWithEnglishTitle(media);
          console.log('Enriched series:', media);
        }
        
        credits = buildTvdbCredits(media);
      } catch (seriesError) {
        console.error('Error fetching series:', seriesError);
        showNotification('Failed to load series details: ' + seriesError.message, true);
        return;
      }
    } else {
      // Handle both 'tmdb_123' format and plain '123' numeric IDs
      const movieId = String(mediaId).replace('tmdb_', '');
      [media, credits] = await Promise.all([
        fetchTMDb(`/movie/${movieId}`),
        fetchTMDb(`/movie/${movieId}/credits`)
      ]);
      media = normalizeMediaItem(media, 'movie');
    }
    
    currentModalMovie = media;
    currentModalCredits = credits;
    const movieInfo = userMovieList.get(String(mediaId)) || {};
    openMovieModal(media, credits, { movieInfo, settings });

    // Wire modal controls here (status, rating, add popover, watchtime):
    const modalContent = document.getElementById('modal-content');

    // Language toggle for series descriptions
    const toggleLangBtn = modalContent.querySelector('#toggle-language-btn');
    if (toggleLangBtn) {
      const overviewText = modalContent.querySelector('#modal-overview-text');
      const titleText = modalContent.querySelector('#modal-title');
      toggleLangBtn.addEventListener('click', () => {
        const currentLang = toggleLangBtn.dataset.showing;
        if (currentLang === 'english') {
          // Switch to original
          const original = overviewText.dataset.overviewOriginal;
          overviewText.textContent = original;
          
          // Also toggle title if available
          if (titleText) {
            const originalTitle = titleText.dataset.titleOriginal;
            if (originalTitle) {
              titleText.textContent = originalTitle;
            }
          }
          
          toggleLangBtn.textContent = 'Show English';
          toggleLangBtn.dataset.showing = 'original';
        } else {
          // Switch to English
          const english = overviewText.dataset.overviewEnglish;
          overviewText.textContent = english;
          
          // Also toggle title if available
          if (titleText) {
            const englishTitle = titleText.dataset.titleEnglish;
            if (englishTitle) {
              titleText.textContent = englishTitle;
            }
          }
          
          toggleLangBtn.textContent = 'Show Original';
          toggleLangBtn.dataset.showing = 'english';
        }
      });
    }

    // Translate button for non-English descriptions
    const translateBtn = modalContent.querySelector('#translate-btn');
    if (translateBtn) {
      const overviewText = modalContent.querySelector('#modal-overview-text');
      translateBtn.addEventListener('click', async () => {
        const originalText = overviewText.textContent;
        
        // Check if AI proxy is available
        const hasAiProxy = typeof window.__gemini_proxy_url !== 'undefined' && window.__gemini_proxy_url;
        if (!hasAiProxy) {
          showNotification('Translation requires a configured AI proxy.', true);
          return;
        }
        
        translateBtn.innerHTML = '<span>Translating...</span>';
        translateBtn.disabled = true;
        
        try {
          const prompt = `Translate the following text to English. Only return the English translation, nothing else:\n\n${originalText}`;
          const payload = { contents: [{ parts: [{ text: prompt }] }] };
          const result = await callGeminiApi(payload);
          const translation = result?.candidates?.[0]?.content?.parts?.[0]?.text || '';
          
          if (translation) {
            // Store the translation
            overviewText.dataset.overviewEnglish = translation;
            overviewText.textContent = translation;
            
            // Replace button with toggle
            translateBtn.remove();
            const descHeader = modalContent.querySelector('.mb-4 .flex');
            if (descHeader) {
              const toggleBtn = document.createElement('button');
              toggleBtn.id = 'toggle-language-btn';
              toggleBtn.type = 'button';
              toggleBtn.className = 'text-xs text-sky-400 hover:text-sky-300 transition-colors';
              toggleBtn.dataset.showing = 'english';
              toggleBtn.textContent = 'Show Original';
              descHeader.appendChild(toggleBtn);
              
              // Add toggle handler
              toggleBtn.addEventListener('click', () => {
                const currentLang = toggleBtn.dataset.showing;
                if (currentLang === 'english') {
                  overviewText.textContent = originalText;
                  toggleBtn.textContent = 'Show English';
                  toggleBtn.dataset.showing = 'original';
                } else {
                  overviewText.textContent = translation;
                  toggleBtn.textContent = 'Show Original';
                  toggleBtn.dataset.showing = 'english';
                }
              });
            }
          } else {
            showNotification('Translation failed. Please try again.', true);
            translateBtn.innerHTML = '<span>Translate to English</span>';
            translateBtn.disabled = false;
          }
        } catch (err) {
          console.error('Translation error:', err);
          let errorMsg = 'Could not translate: ';
          if (err.message.includes('429') || err.message.includes('quota') || err.message.includes('RESOURCE_EXHAUSTED')) {
            errorMsg = 'API quota limit reached. Check your usage at https://aistudio.google.com/apikey or wait and try again.';
          } else {
            errorMsg += err.message;
          }
          showNotification(errorMsg, true);
          translateBtn.innerHTML = '<span>Translate to English</span>';
          translateBtn.disabled = false;
        }
      });
    }

    const statusSelect = modalContent.querySelector('#modal-status-select');
    if (statusSelect) {
      statusSelect.value = movieInfo.status || '';
      statusSelect.addEventListener('change', async () => {
        try {
          const newStatus = statusSelect.value || '';
          await ensureGuestSession();
          await localUpdateMovieStatus(mediaId, media, newStatus);
          // re-render modal so UI updates to show/hide progress/rating label
          currentModalMovie = media;
          currentModalCredits = credits;
          // Re-open modal contents with updated movieInfo
          openMovieModal(media, credits, { movieInfo: userMovieList.get(String(mediaId)) || {}, settings });
        } catch (err) {
          console.error('Status change failed:', err);
          showNotification('Could not update status.', true);
        }
      });
    }

    // Rating input handler (numeric)
    const ratingInput = modalContent.querySelector('#modal-rating-input');
    if (ratingInput) {
      ratingInput.addEventListener('change', async () => {
        try {
          const ratingValue = ratingInput.value.trim();
          if (!ratingValue || isNaN(Number(ratingValue))) return;
          const rating = Number(ratingValue);
          
          // Validate rating based on system
          let isValid = false;
          if (settings.ratingSystem === '1-10') isValid = rating >= 1 && rating <= 10 && Number.isInteger(rating);
          else if (settings.ratingSystem === '1-100') isValid = rating >= 1 && rating <= 100 && Number.isInteger(rating);
          
          if (!isValid) {
            showNotification('Invalid rating value.', true);
            return;
          }
          
          await ensureGuestSession();
          await localUpdateUserRating(mediaId, media, rating);
          
          // Set status to "watched" when rating is entered
          if (!movieInfo.status || movieInfo.status !== 'watched') {
            await localUpdateMovieStatus(mediaId, media, 'watched');
          }
          
          showNotification('Rating saved!', false);
          openMovieModal(media, credits, { movieInfo: userMovieList.get(String(mediaId)) || {}, settings });
        } catch (err) {
          console.error('Rating update failed:', err);
          showNotification('Could not update rating.', true);
        }
      });
    }


    // Add to List button + popover logic
    const addBtn = modalContent.querySelector('#modal-add-to-list-btn');
    const modalPopover = modalContent.querySelector('#modal-add-popover');
    if (addBtn) {
      addBtn.textContent = (movieInfo && (movieInfo.status || movieInfo.rating)) ? 'Remove from list' : 'Add to List';
      addBtn.addEventListener('click', async () => {
        try {
          await ensureGuestSession();
          const isIn = userMovieList.has(String(mediaId));
          if (isIn) {
            await localRemoveMovie(mediaId);
            showNotification('Removed from your list.', false);
            openMovieModal(media, credits, { movieInfo: userMovieList.get(String(mediaId)) || {}, settings });
            return;
          }
          // If a status is selected in the select, use it
          const statusSelectEl = modalContent.querySelector('#modal-status-select');
          const allowed = ['watching','watched','planning'];
          const selected = statusSelectEl ? (statusSelectEl.value || '').trim() : '';
          if (selected && allowed.includes(selected)) {
            await localUpdateMovieStatus(mediaId, media, selected);
            showNotification('Added to your list.', false);
            openMovieModal(media, credits, { movieInfo: userMovieList.get(String(mediaId)) || {}, settings });
            return;
          }
          // Otherwise open the popover and request explicit status
          if (modalPopover) {
            modalPopover.classList.remove('hidden');
            const firstOpt = modalPopover.querySelector('.modal-list-option');
            if (firstOpt) firstOpt.focus();
          }
          addBtn.classList.remove('shake');
          void addBtn.offsetWidth;
          addBtn.classList.add('shake');
          setTimeout(() => addBtn.classList.remove('shake'), 400);
        } catch (err) {
          console.error('Add/remove from modal failed:', err);
          showNotification('Could not update list.', true);
        }
      });

      // Popover option clicks
      if (modalPopover) {
        modalPopover.querySelectorAll('.modal-list-option').forEach(opt => {
          opt.addEventListener('click', async (ev) => {
            ev.stopPropagation();
            const status = opt.dataset.status;
            try {
              await ensureGuestSession();
              await localUpdateMovieStatus(mediaId, media, status);
              showNotification(`Set to ${opt.textContent}.`, false);
              openMovieModal(media, credits, { movieInfo: userMovieList.get(String(mediaId)) || {}, settings });
            } catch (err) {
              console.error('Modal popover set status failed:', err);
              showNotification('Could not update status.', true);
            }
          });
        });

        // hover handlers to keep popover open when interacting
        let modalPopoverHideTimeout = null;
        modalPopover._hovering = false;
        const scheduleHide = () => { if (modalPopoverHideTimeout) clearTimeout(modalPopoverHideTimeout); modalPopoverHideTimeout = setTimeout(() => { if (!modalPopover._hovering) modalPopover.classList.add('hidden'); }, 200); };
        addBtn.addEventListener('mouseenter', () => modalPopover.classList.remove('hidden'));
        addBtn.addEventListener('mouseleave', scheduleHide);
        modalPopover.addEventListener('mouseenter', () => { modalPopover._hovering = true; modalPopover.classList.remove('hidden'); });
        modalPopover.addEventListener('mouseleave', () => { modalPopover._hovering = false; scheduleHide(); });
      }
    }

    // Watch time input wiring (for movies)
    const watchInput = modalContent.querySelector('#modal-watchtime-input');
    if (watchInput) {
      const progressBar = modalContent.querySelector('#modal-progress-bar');
      const progressLabel = modalContent.querySelector('#modal-progress-label');
      watchInput.addEventListener('change', async () => {
        let minutes = Number(watchInput.value);
        if (isNaN(minutes) || minutes < 0) minutes = 0;
        if (media.runtime && minutes > Number(media.runtime)) minutes = Number(media.runtime);
        watchInput.value = minutes;
        try {
          await ensureGuestSession();
          await localUpdateWatchTime(mediaId, media, minutes);
          const pct = media.runtime ? Math.min(100, Math.round((minutes / media.runtime) * 100)) : 0;
          if (progressBar) progressBar.style.width = pct + '%';
          if (progressLabel) progressLabel.textContent = `${pct}% (${minutes} / ${media.runtime || '?'} min)`;
        } catch (err) {
          console.error('Failed to update watch time:', err);
          showNotification('Could not update progress.', true);
        }
      });
    }

    // Episodes input wiring (for TV series)
    const episodesInput = modalContent.querySelector('#modal-episodes-input');
    const seasonSelect = modalContent.querySelector('#modal-season-select');
    const episodesTotal = modalContent.querySelector('#modal-episodes-total');
    const castList = modalContent.querySelector('#modal-cast-list');
    
    if (episodesInput && seasonSelect) {
      const updateSeasonTotal = async (seasonNumber) => {
        if (!episodesTotal) return;
        episodesTotal.textContent = '/ --';
        const total = await getSeasonEpisodeTotal(media, seasonNumber);
        episodesTotal.textContent = typeof total === 'number' ? `/ ${total}` : '/ --';
      };

      const updateSeasonCast = async (seasonNumber) => {
        if (!castList || !media || !media.seasons) return;
        const seasonId = getSeasonIdForNumber(media, seasonNumber);
        if (!seasonId) return;
        castList.innerHTML = '<span class="text-xs text-gray-400">Loading season cast...</span>';
        if (seasonCastCache.has(seasonId)) {
          const cached = seasonCastCache.get(seasonId);
          if (cached && cached.length) {
            castList.innerHTML = cached.map(a => `<a href="#" class="actor-link text-xs bg-gray-700 hover:bg-gray-600 text-gray-300 rounded-full px-3 py-1 transition-colors" data-actor-id="${a.id}" data-actor-name="${a.name}">${a.name}</a>`).join('');
          }
          return;
        }
        const seasonDetails = await getSeasonDetails(seasonId);
        let seasonCast = buildTvdbCastFromData(seasonDetails);

        if (!seasonCast.length && Array.isArray(seasonDetails?.episodes)) {
          const episodes = seasonDetails.episodes.slice(0, 6);
          const episodeDetails = await Promise.all(
            episodes.map((ep) => ep?.id ? getEpisodeDetails(ep.id) : null)
          );
          const episodeCast = episodeDetails.flatMap(ed => buildTvdbCastFromData(ed));
          seasonCast = Array.from(new Map(episodeCast.map(c => [c.name, c])).values());
        }

        seasonCastCache.set(seasonId, seasonCast);
        if (seasonCast && seasonCast.length) {
          castList.innerHTML = seasonCast.map(a => `<a href="#" class="actor-link text-xs bg-gray-700 hover:bg-gray-600 text-gray-300 rounded-full px-3 py-1 transition-colors" data-actor-id="${a.id}" data-actor-name="${a.name}">${a.name}</a>`).join('');
        } else {
          castList.innerHTML = '<span class="text-xs text-gray-400">No season cast available.</span>';
        }
      };

      // Update episodes input when season changes
      seasonSelect.addEventListener('change', () => {
        const selectedSeason = Number(seasonSelect.value);
        const movieInfo = userMovieList.get(String(mediaId)) || {};
        const episodesData = movieInfo.episodesWatched || {};
        const episodes = typeof episodesData === 'object' ? (episodesData[`s${selectedSeason}`] || 0) : 0;
        episodesInput.value = episodes;
        updateSeasonTotal(selectedSeason);
        updateSeasonCast(selectedSeason);
      });
      
      // Save episodes when changed
      episodesInput.addEventListener('change', async () => {
        let episodes = Number(episodesInput.value);
        if (isNaN(episodes) || episodes < 0) episodes = 0;
        episodesInput.value = episodes;
        
        const selectedSeason = Number(seasonSelect.value);
        const movieInfo = userMovieList.get(String(mediaId)) || {};
        const episodesData = typeof movieInfo.episodesWatched === 'object' ? { ...movieInfo.episodesWatched } : {};
        episodesData[`s${selectedSeason}`] = episodes;
        
        try {
          await ensureGuestSession();
          await localUpdateEpisodes(mediaId, media, episodesData, selectedSeason);
          showNotification(`Season ${selectedSeason}: ${episodes} episodes`, false);
          
          // Update the dropdown to show progress
          const options = seasonSelect.querySelectorAll('option');
          options.forEach(opt => {
            const season = Number(opt.value);
            const eps = episodesData[`s${season}`] || 0;
            const progress = eps > 0 ? ` (${eps} eps)` : '';
            opt.textContent = `Season ${season}${progress}`;
          });
        } catch (err) {
          console.error('Failed to update episodes:', err);
          showNotification('Could not update episodes.', true);
        }
      });

      updateSeasonTotal(Number(seasonSelect.value));
      updateSeasonCast(Number(seasonSelect.value));
    }

  } catch (error) {
    showNotification('Could not open movie details.', true);
    console.error(error);
  }
});

// Card-level Add button event (the floating green + on cards)
document.addEventListener('addToListClick', async (e) => {
  const movieId = e.detail.movieId;
  try {
    const movie = await fetchTMDb(`/movie/${movieId}`);
    await ensureGuestSession();
    // default to 'planning' when adding via card
    await localUpdateMovieStatus(movieId, movie, 'planning');
    showNotification('Added to your list!', false);
  } catch (err) {
    console.error('Card add failed:', err);
    showNotification('Could not add movie to your list.', true);
  }
});

// Actor page and tooltip events (forwarded from ui)
document.addEventListener('openActorPage', async (e) => {
  const pid = e.detail.personId;
  try {
    const person = await fetchTMDb(`/person/${pid}`);
    const credits = await fetchTMDb(`/person/${pid}/combined_credits`);
    showActorPage(person, credits);
  } catch (err) {
    console.error('Failed to open actor page:', err);
  }
});

document.addEventListener('showActorTooltip', async (e) => {
  const link = e.detail.link;
  // minimal tooltip handling: fetch and populate
  const tip = document.getElementById('actor-tooltip');
  if (!tip || !link) return;
  const actorId = link.dataset.actorId;
  if (!actorId) return;
  tip.classList.remove('hidden');
  tip.textContent = 'Loading...';
  try {
    const person = await fetchTMDb(`/person/${actorId}`);
    const name = person.name || link.dataset.actorName || '';
    const bio = person.biography ? (person.biography.substring(0,180) + (person.biography.length>180? '…':'')) : 'No biography available.';
    tip.innerHTML = `<div class="font-semibold text-white mb-1">${name}</div><div class="text-xs text-gray-300">${bio}</div>`;
    const rect = link.getBoundingClientRect();
    const docEl = document.documentElement;
    tip.style.left = `${Math.min(Math.max(rect.left, 8), docEl.clientWidth - tip.offsetWidth - 8)}px`;
    tip.style.top = `${rect.bottom + window.scrollY + 8}px`;
  } catch (err) {
    tip.innerHTML = `<div class="text-xs text-gray-300">Could not load preview.</div>`;
  }
});

document.addEventListener('hideActorTooltip', (e) => {
  const tip = document.getElementById('actor-tooltip');
  if (!tip) return;
  tip.classList.add('hidden');
  tip.innerHTML = '';
});

// --- Settings ---
document.getElementById('theme-select').addEventListener('change', (e) => { 
  settings.theme = e.target.value; 
  applyTheme(settings.theme); 
  saveSettings(); 
});
document.getElementById('rating-system-select').addEventListener('change', (e) => { 
  settings.ratingSystem = e.target.value; 
  saveSettings(); 
});
// Set initial values in settings form
document.getElementById('theme-select').value = settings.theme || 'default';
document.getElementById('rating-system-select').value = settings.ratingSystem || '1-10';

// --- Initial load ---
loadHomePageContent();
