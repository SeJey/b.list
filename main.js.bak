// --- Search Handling ---
if (homeSearchForm) {
  homeSearchForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const query = homeSearchInput.value.trim();
    if (query) {
      // Hide carousels and show search results in main grid
      if (upcomingMoviesCarousel) upcomingMoviesCarousel.parentElement.parentElement.classList.add('hidden');
      if (topSeriesGrid) topSeriesGrid.parentElement.classList.add('hidden');
      if (homeGrid) homeGrid.parentElement.classList.remove('hidden');
      
      loader.classList.remove('hidden');
      
      try {
        // Search both movies and TV series in parallel
        const [moviesRes, seriesRes] = await Promise.all([
          fetchTMDb('/search/movie', `query=${encodeURIComponent(query)}`).catch(() => ({ results: [] })),
          searchTVSeries(query).catch(() => [])
        ]);
        
        console.log('Search results - Movies:', moviesRes.results?.length || 0, 'Series:', seriesRes?.length || 0);
        
        // Normalize and combine results
        const movies = (moviesRes.results || []).map(m => {
          try {
            return normalizeMediaItem(m, 'movie');
          } catch (e) {
            console.error('Error normalizing movie:', e, m);
            return null;
          }
        }).filter(Boolean);
        
        const series = (seriesRes || []).map(s => {
          try {
            console.log('Raw TVDB series from search:', s);
            const normalized = normalizeMediaItem(s, 'series');
            console.log('Normalized series:', normalized);
            return normalized;
          } catch (e) {
            console.error('Error normalizing series:', e, s);
            return null;
          }
        }).filter(Boolean);
        
        // Enrich series with English titles if needed (async)
        const enrichedSeries = await Promise.all(
          series.map(s => enrichSeriesWithEnglishTitle(s))
        );
        
        // Mix them together
        const combined = [...movies.slice(0, 15), ...enrichedSeries.slice(0, 15)];
        console.log('Combined results:', combined.length, 'items');
        
        loader.classList.add('hidden');
        renderMovieGrid(homeGrid, combined);
      } catch (err) {
        console.error('Search failed:', err);
        loader.classList.add('hidden');
        showNotification('Search failed. Please try again.', true);
      }
    }
  });
}

